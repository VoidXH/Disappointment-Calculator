<UserControl x:Class="DisappointmentCalculator.MainPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel>
            <Button Margin="10,0,10,10" Padding="25,12,25,12" x:Name="LoadButton" FontSize="30" Click="OnLoadClicked"
                    Content="How much did I waste on AI?"/>
            <ComboBox Name="AggregationPicker" Margin="10" Padding="25,0,0,0" FontSize="20"/>
            <Label Name="StatusLabel" Margin="10,0,10,0" FontSize="10" Content="Make sure no AI sessions are active to prevent data corruption."/>
            <ProgressBar Name="Progress" Margin="10,0,10,0" Value="0" Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</UserControl>
