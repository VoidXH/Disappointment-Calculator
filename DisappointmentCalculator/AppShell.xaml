<Shell
    x:Class="DisappointmentCalculator.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:DisappointmentCalculator"
    Title="Disappointment Calculator">
    <ShellContent
        Title="Fetching"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />
    <ShellContent
        Title="Summary"
        ContentTemplate="{DataTemplate local:SummaryPage}"
        Route="SummaryPage" />
</Shell>
