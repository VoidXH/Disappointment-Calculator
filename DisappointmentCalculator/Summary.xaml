<UserControl x:Class="DisappointmentCalculator.SummaryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:graph="clr-namespace:DisappointmentCalculator.Presentation.Graphs"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="{StaticResource WindowBackgroundBrush}">
    <Grid RowDefinitions="Auto, *, *, Auto" ColumnDefinitions="*, *" Margin="12">
        <Border Grid.Row="0" Grid.Column="0" Margin="12" Padding="16" CornerRadius="16">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Direction="90" BlurRadius="10" ShadowDepth="4" Opacity="0.3"/>
            </Border.Effect>

            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,4">
                    <Label VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Content="Total cash lit on fire:"/>
                    <TextBlock Name="grandTotal" VerticalAlignment="Center" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentRedBrush}"/>
                </StackPanel>
                <TextBlock Name="modelTotal" Foreground="{StaticResource TextMutedBrush}" TextAlignment="Right"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="0" Grid.Column="1" Margin="12" Padding="16" CornerRadius="16">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Direction="90" BlurRadius="10" ShadowDepth="4" Opacity="0.3"/>
            </Border.Effect>

            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,4">
                    <Label VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Content="Tokenmaxxing score:"/>
                    <TextBlock Name="tokenmaxxing" VerticalAlignment="Center" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentBlueBrush}"/>
                </StackPanel>
                <TextBlock Name="tokenTotal" Foreground="{StaticResource TextMutedBrush}" TextAlignment="Right"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Margin="12" Padding="16" CornerRadius="16">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Direction="90" BlurRadius="8" ShadowDepth="4" Opacity="0.2"/>
            </Border.Effect>
            <graph:SelectableGraph x:Name="graph1" SelectedGraphType="Tokens" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Margin="12" Padding="16" CornerRadius="16">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Direction="90" BlurRadius="8" ShadowDepth="4" Opacity="0.2"/>
            </Border.Effect>
            <graph:SelectableGraph x:Name="graph2" SelectedGraphType="TokensPerModel" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        </Border>

        <Border Grid.Row="2" Grid.Column="0" Margin="12" Padding="16" CornerRadius="16">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Direction="90" BlurRadius="8" ShadowDepth="4" Opacity="0.2"/>
            </Border.Effect>
            <graph:SelectableGraph x:Name="graph3" SelectedGraphType="TimeSpentInApi" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        </Border>

        <Border Grid.Row="2" Grid.Column="1" Margin="12" Padding="16" CornerRadius="16">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Direction="90" BlurRadius="8" ShadowDepth="4" Opacity="0.2"/>
            </Border.Effect>
            <graph:SelectableGraph x:Name="graph4" SelectedGraphType="CostPerModel" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        </Border>

        <Label Grid.Row="3" Grid.ColumnSpan="2" Margin="12" HorizontalAlignment="Center" FontSize="13" Foreground="{StaticResource TextWarningBrush}"
               Content="Prices shown are approximates based on token cost snapshots. Not all calculations might be based on AI Credits."/>
    </Grid>
</UserControl>
